{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "resulthub",
  "compatibility_date": "2026-05-22",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "21524e48434296949b8d5adbd71079e2",
  "vars": {
    "NEXT_PUBLIC_APP_URL": "https://resulthub.abrokinla.workers.dev",
    "AUTH_URL": "https://resulthub.abrokinla.workers.dev"
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  }
}
